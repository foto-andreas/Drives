{
  "name": "Fahrtenbuch",
  "version": "1.1.7",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --output-path=../src/main/resources/public",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --runner=vitest --coverage --coverage-reporters=lcov --coverage-reporters=text-summary --coverage-reporters=html",
    "test:ci": "ng test --watch=false --runner=vitest --coverage --coverage-reporters=lcov --coverage-reporters=text-summary --coverage-reporters=html"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "~21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "~21.2.3",
    "@angular/material-luxon-adapter": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@nx/devkit": "^22.6.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3"
  }
}
